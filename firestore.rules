rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function email() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn() && email() == 'leens@nsworld.net';
    }

    function isTeacher() {
      return signedIn() && email().matches('.*@nsworld[.]net$');
    }

    function accessPath() {
      return /databases/$(database)/documents/access/$(email());
    }

    function isCoach() {
      return signedIn() && exists(accessPath()) && get(accessPath()).data.role == 'coach';
    }

    function isHomeroomTeacher() {
      return isTeacher() && exists(accessPath()) && get(accessPath()).data.role == 'teacher';
    }

    function ownsClass(data) {
      return isHomeroomTeacher()
        && data.grade == get(accessPath()).data.grade
        && data.classNo == get(accessPath()).data.classNo;
    }

    function ownsAttendance(data) {
      return isHomeroomTeacher()
        && data.grade == get(accessPath()).data.grade
        && data.classNo == get(accessPath()).data.classNo;
    }

    function validStudent(data) {
      return data.keys().hasOnly(['name', 'grade', 'classNo', 'number', 'departments'])
        && data.name is string
        && data.grade is string
        && data.classNo is string
        && data.number is string
        && data.departments is list
        && data.departments.size() > 0;
    }

    function validAttendance(data) {
      return data.keys().hasOnly(['studentId', 'date', 'grade', 'classNo', 'departments', 'status', 'memo', 'updatedBy', 'updatedAt'])
        && data.studentId is string
        && data.date is string
        && data.grade is string
        && data.classNo is string
        && data.departments is list
        && data.departments.size() > 0
        && data.status in ['present', 'absent', 'late', 'early', 'unset']
        && data.memo is string
        && data.updatedBy == email();
    }

    function coachDepartment() {
      return get(accessPath()).data.department;
    }

    match /settings/public {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /access/{accountEmail} {
      allow read: if isAdmin() || (signedIn() && accountEmail == email());
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || ownsClass(resource.data) || (isCoach() && coachDepartment() in resource.data.departments);
      allow create: if validStudent(request.resource.data) && (isAdmin() || ownsClass(request.resource.data));
      allow update: if validStudent(request.resource.data) && (isAdmin() || (ownsClass(resource.data) && ownsClass(request.resource.data)));
      allow delete: if isAdmin() || ownsClass(resource.data);
    }

    match /contacts/{studentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isAdmin()
        || (ownsAttendance(resource.data))
        || (isCoach() && coachDepartment() in resource.data.departments);
      allow create, update: if validAttendance(request.resource.data)
        && (isAdmin() || ownsAttendance(request.resource.data));
      allow delete: if isAdmin() || ownsAttendance(resource.data);
    }
  }
}
